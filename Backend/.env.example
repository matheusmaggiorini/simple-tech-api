# Simple Tech API — environment variables
# Copy to .env and adjust values

JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080

# Optional: Gemini API key for AI-generated reports
GEMINI_API_KEY=

# Comma-separated frontend origins for CORS
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://127.0.0.1:8080
